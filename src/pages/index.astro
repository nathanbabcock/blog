---
import { getCollection } from "astro:content"
import { Rss } from "@lucide/astro"
import BaseLayout from "../layouts/BaseLayout.astro"

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
)
---

<BaseLayout title="Nathan Babcock">
  <header class="stagger" style="--i: 0">
    <h1>Blog</h1>
    <a href="/rss.xml" aria-label="RSS Feed"><Rss size={18} /></a>
  </header>
  <ul>
    {
      posts.map((post, i) => (
        <li class="stagger" style={`--i: ${i + 1}`}>
          <a href={`/blog/${post.id}/`} class:list={[{ "has-draft": post.data.draft }]}>
            <span>{post.data.title}</span>
            {post.data.draft && <span class="draft">Draft</span>}
          </a>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
              timeZone: "America/Chicago",
            })}
          </time>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--color-surface);
  }

  h1 {
    font-weight: 300;
    font-size: 1.1rem;
    color: var(--color-muted);
  }

  header a {
    color: var(--color-muted);
  }

  header a:hover {
    color: var(--color-accent);
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--spacing-md);
  }

  li a {
    text-decoration: none;
  }

  time {
    color: var(--color-muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    li {
      flex-direction: column;
      gap: 0;
    }
  }

  a.has-draft {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5em;
  }

  .draft {
    font-family: system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-bg);
    background: var(--color-accent);
    border-radius: 4px;
    padding: 0.15em 0.45em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
  }
</style>
