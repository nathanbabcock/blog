---
import { getCollection, render } from "astro:content"
import { ArrowLeft } from "@lucide/astro"
import BaseLayout from "../../layouts/BaseLayout.astro"

export async function getStaticPaths() {
  const posts = await getCollection("blog")
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)
---

<BaseLayout title={post.data.title} ogImage={`/og/${post.id}.png`}>
  <a href="/" class="back" aria-label="Back to blog"><ArrowLeft size={20} /></a>
  <h1 class="stagger" style="--i: 1">
    {post.data.title}
    {post.data.draft && <span class="draft">Draft</span>}
  </h1>
  <time class="stagger" style="--i: 2" datetime={post.data.date.toISOString()}>
    {
      post.data.date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
        timeZone: "America/Chicago",
      })
    }
  </time>
  <div class="prose stagger" style="--i: 3">
    <Content />
  </div>
</BaseLayout>

<style>
  @keyframes fade-only {
    from { opacity: 0; }
  }

  .back {
    position: fixed;
    top: var(--spacing-md);
    left: var(--spacing-md);
    color: var(--color-muted);
    transition: color 0.15s ease;
    animation: fade-only 0.4s ease both;
  }

  @media (prefers-reduced-motion: reduce) {
    .back {
      animation: none;
    }
  }

  .back:hover {
    color: var(--color-accent);
  }

  h1 {
    font-size: 1.8rem;
    line-height: 1.3;
    margin-bottom: var(--spacing-sm);
  }

  time {
    display: block;
    color: var(--color-muted);
    font-size: 0.85rem;
    margin-bottom: var(--spacing-xl);
  }

  .draft {
    font-family: system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-bg);
    background: var(--color-accent);
    border-radius: 4px;
    padding: 0.15em 0.45em;
    margin-left: 0.5em;
    vertical-align: middle;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
  }
</style>
