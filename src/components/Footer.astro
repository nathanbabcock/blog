---
import { Github, Linkedin } from "@lucide/astro"
import { GITHUB_URL, LINKEDIN_URL } from "../config"
---

<footer>
  <span>&copy; {new Date().getFullYear()} Nathan Babcock</span>
  <nav>
    <a href={GITHUB_URL} aria-label="GitHub" target="_blank" rel="noopener noreferrer">
      <Github size={18} />
    </a>
    <a href={LINKEDIN_URL} aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
      <Linkedin size={18} />
    </a>
  </nav>
</footer>

<style>
  footer {
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--spacing-lg) var(--spacing-md);
    border-top: 1px solid var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    color: var(--color-muted);
    font-size: 0.8rem;
  }

  nav {
    display: flex;
    gap: var(--spacing-sm);
  }

  a {
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  a:hover {
    color: var(--color-muted);
  }
</style>
